DB_NAME=mini-utm
DB_USERNAME=postgres
DB_PASSWORD=123456
DB_PORT=5433
DB_URL=jdbc:postgresql://localhost:5433/mini-utm
SPRING_PROFILES_ACTIVE=local
TELEMETRY_RETENTION_ENABLED=true
TELEMETRY_RETENTION_DAYS=90
TELEMETRY_RETENTION_BATCH_SIZE=1000
TELEMETRY_RETENTION_CRON=0 0 3 * * *
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALERT_LOW_BATTERY_THRESHOLD=20
ALERT_LOW_BATTERY_RECOVERY_THRESHOLD=25
ALERT_TELEMETRY_LOSS_ENABLED=true
ALERT_TELEMETRY_LOSS_TIMEOUT=60s
ALERT_TELEMETRY_LOSS_SCAN_INTERVAL=30s
ALERT_ROUTE_DEVIATION_CORRIDOR_METERS=100
